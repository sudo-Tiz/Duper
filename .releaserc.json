{
  "branches": ["main"],
  "tagFormat": "v${version}",
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    ["@semantic-release/github", {
      "assets": [
        {"path": "app/build/outputs/apk/release/*.apk", "label": "Android APK"}
      ]
    }]
  ]
}
